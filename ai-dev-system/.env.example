# ── Google Gemini (REQUIRED) ─────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── GitLab (REQUIRED for PR Agent) ───────────────────────────────────────────
GITLAB_PERSONAL_ACCESS_TOKEN=your_gitlab_token_here
GITLAB_URL=https://gitlab.com
GITLAB_REPOSITORY=your-org/your-repo

# ── LangSmith (OPTIONAL — only needed for trace observability) ───────────────
# Sign up at https://smith.langchain.com and create a project.
# Leave these commented out to run without any external observability.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=ai-dev-system
